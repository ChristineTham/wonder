---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	id: string;
	image: ImageMetadata;
	title: string;
	description: string;
	dataPosition?: string;
}

const { image, title, description, dataPosition } = Astro.props;

const optimizedThumb = await getImage({ src: image, width: 600, format: 'webp' });
const optimizedFull = await getImage({ src: image, format: 'webp' });
---
<article class="thumb">
	<a 
		href={optimizedFull.src}
		class="image" 
		style={`background-image: url(${optimizedThumb.src}); background-position: ${dataPosition || 'center'};`}
		data-pswp-width={image.width}
		data-pswp-height={image.height}
		target="_blank"
	>
		<Image src={image} width={600} alt="" style="display: none;" />
	</a>
	<h2>{title}</h2>
	<p>{description}</p>
</article>


<style lang="scss">
	@use 'sass:math';
	@import '../styles/libs';

	.thumb {
		transition: opacity 1.25s ease-in-out;
		pointer-events: auto;
		-webkit-tap-highlight-color: rgba(255,255,255,0);
		opacity: 1;
		overflow: hidden;
		position: relative;

		&::after {
			background-image: linear-gradient(to top, rgba(10,17,25,0.35) 5%, rgba(10,17,25,0) 35%);
			pointer-events: none;
			background-size: cover;
			content: '';
			display: block;
			height: 100%;
			left: 0;
			position: absolute;
			top: 0;
			width: 100%;
		}

		> .image {
			-webkit-tap-highlight-color: rgba(255,255,255,0);
			background-position: center;
			background-repeat: no-repeat;
			background-size: cover;
			border: 0;
			height: 100%;
			left: 0;
			position: absolute;
			top: 0;
			width: 100%;

			img {
				display: none;
			}
		}

		> h2 {
			pointer-events: none;
			bottom: math.div(1.5em, 0.8);
			font-size: 0.8em;
			left: math.div(1.75em, 0.8);
			margin: 0;
			position: absolute;
			z-index: 1;
		}

		> p {
			display: none;
		}

		:global(body.is-preload) & {
			pointer-events: none;
			opacity: 0;
		}
	}
</style>
