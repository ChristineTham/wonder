---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/main.scss';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<noscript><link rel="stylesheet" href="/css/noscript.css" /></noscript>
	</head>
	<body 
		x-data={`{ 
			isPreload: true, 
			isResizing: false,
			resizeTimeout: null
		}`} 
		:class={`{ 
			'is-preload': isPreload, 
			'is-resizing': isResizing, 
			'content-active': $store.panel.active 
		}`}
		@load.window={`setTimeout(() => isPreload = false, 100)`}
		@resize.window={`
			clearTimeout(resizeTimeout); 
			isResizing = true; 
			resizeTimeout = setTimeout(() => isResizing = false, 100)
		`}
		@keyup.escape.window={`$store.panel.hide()`}
		@click={`$store.panel.active ? $store.panel.hide() : null`}
	>
		<div id="wrapper">
			<slot />
		</div>

		<!-- Scripts -->
		<script is:inline src="/js/browser.min.js"></script>
		<script is:inline src="/js/breakpoints.min.js"></script>
		<script>
			import '../scripts/main.js';
		</script>
	</body>
</html>

<style is:global>
	/* Any global styles if needed */
</style>
